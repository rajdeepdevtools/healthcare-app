{
  "name": "devi-homeopathy-clinic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm --prefix backend start",
    "build": "npm --prefix backend install",
    "dev": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors yellow,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
